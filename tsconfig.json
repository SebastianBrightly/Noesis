{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*":["src/*"],
      "@/assets/*": ["assets/*"]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "manifest.json",
    "styles.css",
    "assets/**/*",
    "assets/**/*.jpeg",
    "assets/**/*.jpg",
    "assets/**/*.png",
    "**/declarations.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
} 
